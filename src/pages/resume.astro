---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Rich Parrish">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <!-- Back Link -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-ink-muted hover:text-ink transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Portfolio
    </a>

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-ink">Resume</h1>
      <a
        href="https://docs.google.com/document/d/1DE00gVeBJwm54ehr3W_n-0dEWjGgo4FJ/export?format=pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border text-sm font-medium text-ink hover:bg-cream-dark transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download PDF
      </a>
    </div>

    <!-- Google Doc Embed -->
    <iframe
      src="https://docs.google.com/document/d/1DE00gVeBJwm54ehr3W_n-0dEWjGgo4FJ/preview"
      class="w-full border-0"
      style="height: 1200px;"
      title="Rich Parrish Resume"
      loading="lazy"
      scrolling="no"
    ></iframe>
  </div>
</BaseLayout>
