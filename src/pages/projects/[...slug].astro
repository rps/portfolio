---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, tagline, stack, architecture, metrics, keyDecisions, links, tags } = project.data;

const tagColors: Record<string, string> = {
  'Mobile': 'bg-tag-mobile-bg text-tag-mobile',
  'Web': 'bg-tag-web-bg text-tag-web',
  'Extension': 'bg-tag-extension-bg text-tag-extension',
  'AI': 'bg-tag-ai-bg text-tag-ai',
};
---

<BaseLayout title={`${title} — Rich Parrish`} description={tagline}>
  <article class="max-w-4xl mx-auto px-6 py-12">
    <!-- Back Link -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-ink-muted hover:text-ink transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Portfolio
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-5 flex-wrap">
        <h1 class="text-3xl sm:text-4xl font-bold text-ink tracking-tight">{title}</h1>
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag: string) => (
            <span class={`pill ${tagColors[tag] || 'bg-cream-dark text-ink-muted'}`}>{tag}</span>
          ))}
        </div>
      </div>
      <p class="mt-2 text-lg text-ink-light">{tagline}</p>

      <!-- Action Buttons -->
      <div class="mt-6 flex flex-wrap gap-3">
        {links.betaAccess && (
          <button
            class="beta-access-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-ink text-white text-sm font-medium hover:bg-ink-light transition-colors"
            data-project={title}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Request Beta Access
          </button>
        )}
        {links.demo && (
          <a href={links.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border text-sm font-medium text-ink hover:bg-cream-dark transition-colors">
            Live Demo
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
        {links.github && (
          <a href={links.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border text-sm font-medium text-ink hover:bg-cream-dark transition-colors">
            GitHub
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        )}
      </div>
    </header>

    <!-- Beta Access Modal (hidden by default) -->
    {links.betaAccess && (
      <div id="beta-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/40" id="beta-backdrop"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
          <h3 class="text-lg font-semibold text-ink mb-1">Request Beta Access</h3>
          <p class="text-sm text-ink-muted mb-4">We'll send you an invite to test <strong>{title}</strong>.</p>
          <form id="beta-form" class="space-y-3">
            <input type="hidden" name="project" value={title} />
            <input type="text" name="name" placeholder="Your name" required class="w-full px-3 py-2 rounded-lg border border-border text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent" />
            <input type="email" name="email" placeholder="Your email" required class="w-full px-3 py-2 rounded-lg border border-border text-sm focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent" />
            <div class="flex gap-2 pt-1">
              <button type="submit" class="flex-1 px-4 py-2 rounded-lg bg-ink text-white text-sm font-medium hover:bg-ink-light transition-colors">Send Request</button>
              <button type="button" id="beta-cancel" class="px-4 py-2 rounded-lg border border-border text-sm text-ink-muted hover:bg-cream-dark transition-colors">Cancel</button>
            </div>
          </form>
          <div id="beta-success" class="hidden text-center py-4">
            <p class="text-ink font-medium">Request sent!</p>
            <p class="text-sm text-ink-muted mt-1">You'll hear back soon.</p>
          </div>
        </div>
      </div>
    )}

    <!-- MDX Content (Problem, Visual Demo, Solution sections) -->
    <div class="project-content prose prose-lg max-w-none
      prose-headings:text-ink prose-headings:font-semibold prose-headings:tracking-tight
      prose-h2:text-xl
      prose-p:text-ink-light prose-p:leading-relaxed
      prose-strong:text-ink prose-strong:font-semibold
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-code:text-sm prose-code:bg-cream-dark prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-[#1e1e2e] prose-pre:rounded-xl
      prose-li:text-ink-light
      prose-img:rounded-xl prose-img:border prose-img:border-border
      fade-in-section">
      <Content />
    </div>

    <!-- Key Decisions -->
    {keyDecisions.length > 0 && (
      <section class="mt-12 fade-in-section">
        <h2 class="text-xl font-semibold text-ink pb-2 border-b border-border mb-4">Key Technical Decisions</h2>
        <div class="space-y-4">
          {keyDecisions.map((decision: { title: string; description: string }) => (
            <div class="bg-white rounded-xl border border-border p-5">
              <h3 class="font-medium text-ink text-sm">{decision.title}</h3>
              <p class="mt-1 text-sm text-ink-muted">{decision.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Architecture -->
    <section class="mt-12 fade-in-section">
      <h2 class="text-xl font-semibold text-ink pb-2 border-b border-border mb-4">Architecture</h2>
      <div class="bg-white rounded-xl border border-border p-6">
        <p class="text-sm text-ink-light font-mono leading-relaxed whitespace-pre-wrap">{architecture}</p>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="mt-12 fade-in-section">
      <h2 class="text-xl font-semibold text-ink pb-2 border-b border-border mb-4">Tech Stack</h2>
      <div class="flex flex-wrap gap-2">
        {stack.map((tech: string) => (
          <span class="px-3 py-1.5 rounded-full text-sm bg-white border border-border text-ink-light">
            {tech}
          </span>
        ))}
      </div>
    </section>

    <!-- Metrics -->
    {metrics.length > 0 && (
      <section class="mt-12 fade-in-section">
        <h2 class="text-xl font-semibold text-ink pb-2 border-b border-border mb-4">By the Numbers</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {metrics.map((metric: string) => (
            <div class="bg-white rounded-xl border border-border p-4">
              <p class="text-sm text-ink-light">{metric}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Back to top -->
    <div class="mt-12 pt-6 border-t border-border">
      <a href="/" class="inline-flex items-center gap-1 text-sm text-ink-muted hover:text-ink transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Portfolio
      </a>
    </div>
  </article>

  <!-- Beta Access Script -->
  <script>
    const modal = document.getElementById('beta-modal');
    const backdrop = document.getElementById('beta-backdrop');
    const form = document.getElementById('beta-form') as HTMLFormElement | null;
    const cancel = document.getElementById('beta-cancel');
    const success = document.getElementById('beta-success');

    document.querySelectorAll('.beta-access-btn').forEach((btn) => {
      btn.addEventListener('click', () => modal?.classList.remove('hidden'));
    });

    cancel?.addEventListener('click', () => modal?.classList.add('hidden'));
    backdrop?.addEventListener('click', () => modal?.classList.add('hidden'));

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      try {
        await fetch('/api/request-access', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            project: formData.get('project'),
          }),
        });
      } catch (_) {
        // Silently handle - show success anyway since worst case Rich gets no email
      }
      form.classList.add('hidden');
      success?.classList.remove('hidden');
      setTimeout(() => modal?.classList.add('hidden'), 2000);
    });
  </script>
</BaseLayout>
