---
interface Screenshot {
  src: string;
  caption: string;
}

interface Props {
  screenshots: Screenshot[];
  device?: "phone" | "tablet" | "browser";
}

const { screenshots, device = "phone" } = Astro.props;
---

<div class="not-prose screenshot-gallery-wrapper">
  <button class="gallery-nav gallery-nav-prev" aria-label="Scroll left">&#8249;</button>
  <button class="gallery-nav gallery-nav-next" aria-label="Scroll right">&#8250;</button>
  <div class="screenshot-gallery">
    <div class="gallery-scroll">
      {screenshots.map((shot, i) => (
        <button class="gallery-item" data-gallery-trigger data-index={i} type="button">
          <div class={`device-frame device-${device}`}>
            <div class="device-screen">
              <img src={shot.src} alt={shot.caption} loading="lazy" />
            </div>
          </div>
          {shot.caption && <p class="gallery-caption">{shot.caption}</p>}
        </button>
      ))}
    </div>
  </div>
</div>

<div class="lightbox" id="screenshot-lightbox" role="dialog" aria-modal="true" aria-label="Screenshot viewer">
  <button class="lightbox-close" aria-label="Close">&times;</button>
  <button class="lightbox-prev" aria-label="Previous screenshot">&#8249;</button>
  <button class="lightbox-next" aria-label="Next screenshot">&#8250;</button>
  <div class="lightbox-content">
    <div class={`device-frame device-${device} lightbox-device`}>
      <div class="device-screen">
        <img src="" alt="" id="lightbox-img" />
      </div>
    </div>
    <p class="lightbox-caption" id="lightbox-caption"></p>
  </div>
</div>

<style>
  /* Gallery layout */
  .screenshot-gallery-wrapper {
    position: relative;
    margin: 0.5rem 0;
  }

  .screenshot-gallery {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .gallery-scroll {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    padding: 0.75rem 0.25rem;
    width: max-content;
    min-width: 100%;
  }

  /* Gallery hover nav buttons */
  .gallery-nav {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: rgba(30, 30, 30, 0.7);
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    color: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    align-items: center;
    justify-content: center;
  }

  .gallery-nav-prev { left: 0.5rem; }
  .gallery-nav-next { right: 0.5rem; }

  .screenshot-gallery-wrapper:hover .gallery-nav.visible {
    display: flex;
    opacity: 0.7;
  }

  .gallery-nav:hover {
    opacity: 1 !important;
  }

  .gallery-item {
    flex-shrink: 0;
    text-align: center;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .gallery-caption {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-top: 0.75rem;
    font-weight: 500;
  }

  /* Phone frame */
  .device-phone {
    width: 175px;
    background: #1a1a1a;
    border-radius: 28px;
    padding: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery-item:hover .device-phone {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .device-phone .device-screen {
    border-radius: 20px;
    overflow: hidden;
  }

  .device-screen img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Tablet frame */
  .device-tablet {
    width: 480px;
    background: #1a1a1a;
    border-radius: 20px;
    padding: 10px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery-item:hover .device-tablet {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .device-tablet .device-screen {
    border-radius: 12px;
    overflow: hidden;
  }

  /* Browser frame */
  .device-browser {
    width: 100%;
    max-width: 680px;
    background: #f0f0f0;
    border-radius: 10px;
    padding-top: 32px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .device-browser::before {
    content: "";
    position: absolute;
    top: 10px;
    left: 12px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ff5f57;
    box-shadow: 20px 0 0 #febc2e, 40px 0 0 #28c840;
  }

  .gallery-item:hover .device-browser {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .device-browser .device-screen {
    overflow: hidden;
    border-radius: 0 0 10px 10px;
  }

  /* Lightbox — :global because JS moves it to document.body */
  :global(.lightbox) {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(30, 28, 25, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 0;
    margin: 0;
    border: none;
  }

  :global(.lightbox.active) {
    display: flex;
  }

  :global(.lightbox .lightbox-content) {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-height: 85vh;
  }

  :global(.lightbox .lightbox-device.device-phone) {
    width: auto;
    border-radius: 36px;
    padding: 10px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  :global(.lightbox .lightbox-device.device-phone .device-screen) {
    border-radius: 26px;
    overflow: hidden;
  }

  :global(.lightbox .lightbox-device .device-screen img) {
    max-height: 75vh;
    width: auto;
    display: block;
  }

  :global(.lightbox .lightbox-device.device-tablet) {
    width: 680px;
    max-width: 90vw;
  }

  :global(.lightbox .lightbox-device.device-browser) {
    width: 900px;
    max-width: 90vw;
  }

  :global(.lightbox .lightbox-close) {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1;
    opacity: 0.5;
    transition: opacity 0.15s;
    line-height: 1;
    padding: 0;
  }

  :global(.lightbox .lightbox-close:hover) {
    opacity: 1;
  }

  :global(.lightbox .lightbox-prev),
  :global(.lightbox .lightbox-next) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 3rem;
    background: none;
    border: none;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.15s;
    padding: 1rem;
    z-index: 1;
    line-height: 1;
  }

  :global(.lightbox .lightbox-prev:hover),
  :global(.lightbox .lightbox-next:hover) {
    opacity: 1;
  }

  :global(.lightbox .lightbox-prev) { left: 0.5rem; }
  :global(.lightbox .lightbox-next) { right: 0.5rem; }

  :global(.lightbox .lightbox-caption) {
    color: rgba(255, 255, 255, 0.6);
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .gallery-scroll {
      justify-content: flex-start;
      padding-left: 0.25rem;
      padding-right: 1rem;
    }

    .device-phone {
      width: 150px;
      border-radius: 24px;
      padding: 6px;
    }

    .device-phone .device-screen {
      border-radius: 18px;
    }

    :global(.lightbox .lightbox-device.device-phone) {
      border-radius: 30px;
      padding: 8px;
    }

    :global(.lightbox .lightbox-device.device-phone .device-screen) {
      border-radius: 22px;
    }

    :global(.lightbox .lightbox-device .device-screen img) {
      max-height: 65vh;
    }

    :global(.lightbox .lightbox-prev),
    :global(.lightbox .lightbox-next) {
      font-size: 2rem;
      padding: 0.5rem;
    }
  }
</style>

<script>
  function initGallery() {
    const triggers = document.querySelectorAll("[data-gallery-trigger]");
    const lightbox = document.getElementById("screenshot-lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const lightboxCaption = document.getElementById("lightbox-caption");

    if (!triggers.length || !lightbox || !lightboxImg || !lightboxCaption) return;

    // Move lightbox to body so ancestor transforms don't break position:fixed
    document.body.appendChild(lightbox);

    const srcs: string[] = [];
    const captions: string[] = [];
    let current = 0;

    triggers.forEach((trigger) => {
      const img = trigger.querySelector("img") as HTMLImageElement;
      if (img) {
        srcs.push(img.src);
        captions.push(img.alt);
      }
    });

    function show(index: number) {
      current = ((index % srcs.length) + srcs.length) % srcs.length;
      lightboxImg.src = srcs[current];
      lightboxImg.alt = captions[current];
      lightboxCaption!.textContent = captions[current];
    }

    function open(index: number) {
      show(index);
      lightbox!.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    function close() {
      lightbox!.classList.remove("active");
      document.body.style.overflow = "";
    }

    triggers.forEach((trigger, i) => {
      trigger.addEventListener("click", () => open(i));
    });

    lightbox.querySelector(".lightbox-close")?.addEventListener("click", close);
    lightbox.querySelector(".lightbox-prev")?.addEventListener("click", () => show(current - 1));
    lightbox.querySelector(".lightbox-next")?.addEventListener("click", () => show(current + 1));

    lightbox.addEventListener("click", (e) => {
      const target = e.target as Element;
      if (!target.closest(".lightbox-content") && !target.closest("button")) close();
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox!.classList.contains("active")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });

    // Lightbox touch swipe
    let touchStartX = 0;
    let touchStartY = 0;

    lightbox.addEventListener("touchstart", (e) => {
      touchStartX = e.changedTouches[0].clientX;
      touchStartY = e.changedTouches[0].clientY;
    }, { passive: true });

    lightbox.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0) show(current - 1);
        else show(current + 1);
      }
    }, { passive: true });

    // Gallery scroll nav buttons
    const wrapper = document.querySelector(".screenshot-gallery-wrapper");
    const scrollEl = wrapper?.querySelector(".screenshot-gallery");
    const prevBtn = wrapper?.querySelector(".gallery-nav-prev");
    const nextBtn = wrapper?.querySelector(".gallery-nav-next");

    if (scrollEl && prevBtn && nextBtn) {
      function updateNavVisibility() {
        const el = scrollEl as HTMLElement;
        const canScroll = el.scrollWidth > el.clientWidth;
        prevBtn!.classList.toggle("visible", canScroll && el.scrollLeft > 1);
        nextBtn!.classList.toggle("visible", canScroll && el.scrollLeft < el.scrollWidth - el.clientWidth - 1);
      }

      prevBtn.addEventListener("click", () => {
        (scrollEl as HTMLElement).scrollBy({ left: -200, behavior: "smooth" });
      });

      nextBtn.addEventListener("click", () => {
        (scrollEl as HTMLElement).scrollBy({ left: 200, behavior: "smooth" });
      });

      scrollEl.addEventListener("scroll", updateNavVisibility, { passive: true });
      window.addEventListener("resize", updateNavVisibility);
      updateNavVisibility();
    }
  }

  initGallery();
</script>
